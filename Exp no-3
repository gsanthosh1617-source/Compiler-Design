#include <stdio.h>
int main() {
    char s[500];
    int i = 0;
    printf("Enter code: ");
    fgets(s, 500, stdin);
    while (s[i] != '\0') {
        if (s[i] == '/' && s[i + 1] == '/') {
            break;
        }
        else if (s[i] == '/' && s[i + 1] == '*') {
            i += 2;
            while (s[i] && !(s[i] == '*' && s[i + 1] == '/'))
                i++;
            i += 2;
        }
        else if (s[i] != ' ' && s[i] != '\t' && s[i] != '\n') {
            printf("%c", s[i]);
            i++;
        }
        else
            i++;
    }
    return 0;
}

