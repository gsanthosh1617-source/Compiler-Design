#include <stdio.h>
#include <string.h>
int main() {
    char s[200];
    printf("Enter a line: ");
    fgets(s, 200, stdin);
    if (s[0] == '/' && s[1] == '/')
        printf("Single-line Comment");
    else if (s[0] == '/' && s[1] == '*' &&
             strstr(s, "*/") != NULL)
        printf("Multi-line Comment");
    else
        printf("Not a Comment");
    return 0;
}

Input:
// This is a comment
Output:
Single-line Comment
