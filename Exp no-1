#include <stdio.h>
#include <ctype.h>
int main() {
    char s[100];
    int i = 0;
    printf("Enter C code: ");
    fgets(s, 100, stdin);

    while (s[i] != '\0') {
        if (isspace(s[i])) {
            i++;
        }
        else if (isalpha(s[i])) {
            printf("Identifier: ");
            while (isalnum(s[i])) {
                printf("%c", s[i]);
                i++;
            }
            printf("\n");
        }
        else if (isdigit(s[i])) {
            printf("Constant: ");
            while (isdigit(s[i])) {
                printf("%c", s[i]);
                i++;
            }
            printf("\n");
        }
        else if (s[i] == '+' || s[i] == '-' || s[i] == '*' ||
                 s[i] == '/' || s[i] == '=') {
            printf("Operator: %c\n", s[i]);
            i++;
        }
        else {
            i++;
        }
    }
    return 0;
}
Input:
int a = 10 + 20
Output:
Identifier: int
Identifier: a
Operator: =
Constant: 10
Operator: +
Constant: 20
